{
    "manifest_version": 3,
    "name": "ColorGenerator",
    "version": "1.0",
    "devtools_page": "src/extension/devtools.html",
    "content_scripts": [
        {
            "js": ["src/extension/contentScript.ts"],
            "matches": ["<all_urls>"]
        }
    ],
    "icons": {
        "16": "favicon16.png",
        "32": "favicon32.png",
        "48": "favicon48.png",
        "128": "favicon128.png"
    }
}
